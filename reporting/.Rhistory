library(dplyr)
library(ggplot2)
# Step 1: Create bins and compute summary stats
breaks <- c(10, 20, 50, 100, 200, Inf)  # adjust based on your data
zip_summary_binned <- zip_summary %>%
filter(industry_zip_count >= 10) %>%
mutate(
bin = cut(industry_zip_count, breaks = breaks, include.lowest = TRUE, right = FALSE)
) %>%
group_by(industry_categorized, bin) %>%
summarise(
avg_stars_bin = mean(avg_stars, na.rm = TRUE),
sd_stars_bin  = sd(avg_stars, na.rm = TRUE),
n_zips        = n(),
.groups = "drop"
) %>%
# compute midpoint of each bin for plotting
mutate(
bin_mid = (as.numeric(sub("\\[(\\d+),.*", "\\1", bin)) + as.numeric(sub(".*, *(\\d+)\\]", "\\1", bin)))/2
)
# Step 2: Plot
ggplot(zip_summary %>% filter(industry_zip_count >= 10), aes(x = industry_zip_count, y = avg_stars)) +
geom_point(alpha = 0.3) +                       # scatter of individual ZIPs
geom_smooth(method = "loess", se = TRUE, color = "blue") +  # smoothed trend
# binned points
geom_point(
data = zip_summary_binned,
aes(x = bin_mid, y = avg_stars_bin, size = n_zips),
color = "red"
) +
# error bars for bins
geom_errorbar(
data = zip_summary_binned,
aes(
x = bin_mid,
ymin = avg_stars_bin - sd_stars_bin,
ymax = avg_stars_bin + sd_stars_bin
),
width = 0.1,
color = "red"
) +
scale_x_log10() +
facet_wrap(~ industry_categorized) +
labs(
title = "Average Yelp Rating vs Same-Industry Business Density (Binned)",
x = "Same-Industry Businesses per ZIP (log scale)",
y = "Average Yelp Star Rating",
size = "Number of ZIPs in Bin"
) +
theme_minimal()
View(zip_summary_filtered)
View(zip_summary_binned)
library(dplyr)
library(ggplot2)
# Step 1: Filter and create binned summary
breaks <- c(10, 20, 50, 100, 200, Inf)  # adjust based on your data
zip_summary_filtered <- zip_summary %>%
filter(industry_zip_count >= 10)  # optional, keep only higher-density ZIPs
zip_summary_binned <- zip_summary_filtered %>%
mutate(
bin = cut(industry_zip_count, breaks = breaks, include.lowest = TRUE, right = FALSE)
) %>%
group_by(industry_categorized, bin) %>%
summarise(
avg_stars_bin = mean(avg_stars, na.rm = TRUE),
sd_stars_bin  = sd(avg_stars, na.rm = TRUE),
n_zips        = n(),
.groups = "drop"
) %>%
# Compute midpoint of each bin for plotting on log-scale
mutate(
bin_mid = (as.numeric(sub("\\[(\\d+),.*", "\\1", bin)) +
as.numeric(sub(".*, *(\\d+)\\]", "\\1", bin)))/2
)
# Step 2: Plot
ggplot(zip_summary_filtered, aes(x = industry_zip_count, y = avg_stars)) +
geom_point(alpha = 0.3) +                       # scatter of individual ZIPs
geom_smooth(method = "loess", se = TRUE, color = "blue") +  # smoothed trend
# binned points
geom_point(
data = zip_summary_binned,
aes(x = bin_mid, y = avg_stars_bin, size = n_zips),
color = "red"
) +
# error bars for bins
geom_errorbar(
data = zip_summary_binned,
aes(
x = bin_mid,
ymin = avg_stars_bin - sd_stars_bin,
ymax = avg_stars_bin + sd_stars_bin
),
width = 0.1,
color = "red"
) +
scale_x_log10() +
facet_wrap(~ industry_categorized) +
labs(
title = "Average Yelp Rating vs Same-Industry Business Density (Binned)",
x = "Same-Industry Businesses per ZIP (log scale)",
y = "Average Yelp Star Rating",
size = "Number of ZIPs in Bin"
) +
theme_minimal()
# Filter to only ZIP codes with 10 or more businesses
zip_summary_filtered <- zip_summary %>%
filter(industry_zip_count >= 10)
ggplot(
zip_summary_filtered,
aes(x = industry_zip_count, y = avg_stars)
) +
geom_point(alpha = 0.5) +
geom_smooth(method = "loess", se = TRUE) +
geom_smooth(method = "lm", se = TRUE, color = "red") +
scale_x_log10() +
facet_wrap(~ industry_categorized) +
labs(
title = "Average Yelp Rating vs Same-Industry Business Density (Ascending order)",
x = "Same-Industry Businesses per ZIP (log scale)",
y = "Average Yelp Star Rating"
) +
theme_minimal()
